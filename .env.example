# Django / Render Web Service
SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Leave unset for local SQLite. Set this in Render from the Render PostgreSQL
# internal connection string when the Web Service and PostgreSQL are in the
# same Render workspace and region.
DATABASE_URL=

# React / Vercel origins that are allowed to call the Django API.
FRONTEND_ORIGIN=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Cross-site cookies are required when Vercel and Render are on different
# domains in production.
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# OCR is configured later. Never commit the real credential file.
GOOGLE_APPLICATION_CREDENTIALS=
